# GW 0.5.0 declares `peer react@>=19` but its transitive deps
# (@headlessui/react 1.7.12, react-leaflet 4.2, mobx-react-lite 3,
# react-resizable-panels 1, …) all cap React at ^18.  Using React 18 is
# consistent with the actual runtime expectations; the peer-dep strict
# mismatch is silenced here.
legacy-peer-deps=true
