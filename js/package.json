{
  "name": "gw-polars-viz-build",
  "private": true,
  "version": "0.0.0",
  "description": "Build script that bundles Graphic Walker + React into polars_gw/viz_assets/ so the Python viz extra ships a self-contained browser UI.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "clean": "node -e \"require('node:fs').rmSync('../polars_gw/viz_assets/graphic-walker.js',{force:true});require('node:fs').rmSync('../polars_gw/viz_assets/graphic-walker.css',{force:true})\""
  },
  "dependencies": {
    "@kanaries/graphic-walker": "0.5.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
